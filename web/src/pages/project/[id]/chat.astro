---
// src/pages/project/[id]/chat.astro
import Page from '../../../layouts/Page.astro';
import { TabBar } from '../../../components/islands/ui/TabBar';
import ChatView from '../../../components/islands/features/ChatView';

export function getStaticPaths() {
  const ids = ['runway-q3', 'billing-v2', 'untitled'];
  for (let i = 1; i <= 20; i++) {
    ids.push(`untitled-${i}`);
  }
  return ids.map(id => ({ params: { id } }));
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/');
}
---

<Page title="Team Chat — Orca">
  <TabBar currentTab="chat" projectId={id} client:load />
  <ChatView projectId={id} client:only="react">
    <div class="flex-grow flex bg-background lg:h-[calc(100vh-104px)] w-full"></div>
  </ChatView>
</Page>
