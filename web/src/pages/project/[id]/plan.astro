---
// src/pages/project/[id]/plan.astro
import Page from '../../../layouts/Page.astro';
import { TabBar } from '../../../components/islands/ui/TabBar';
import PlanView from '../../../components/islands/features/PlanView';

export function getStaticPaths() {
  const ids = ['runway-q3', 'billing-v2', 'untitled'];
  for (let i = 1; i <= 20; i++) {
    ids.push(`untitled-${i}`);
  }
  return ids.map(id => ({ params: { id } }));
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/');
}
---

<Page title="Project Plan — Orca">
  <TabBar currentTab="plan" projectId={id} client:load />
  <PlanView projectId={id} client:only="react">
    <div class="flex-grow flex bg-background w-full"></div>
  </PlanView>
</Page>
