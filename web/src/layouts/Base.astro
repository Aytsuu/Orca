---
// src/layouts/Base.astro
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Orca Plan - AI Project Planner", 
  description = "Automated AI PM agent that generates implementation plans from conversation logs." 
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/orca_logo.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter transition:animate="none" />
  </head>
  <body>
    <slot />
  </body>
</html>
