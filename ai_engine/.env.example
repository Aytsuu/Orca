APP_ENV=local
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_FAST_MODEL=gemini-2.5-flash-lite
LLM_API_KEY=
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_PROVIDER=gemini
LLM_FALLBACK_MODEL=gemini-2.5-flash
LLM_FALLBACK_FAST_MODEL=gemini-2.5-flash-lite
LLM_FALLBACK_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
REDIS_URL=redis://localhost:6379/0
AGENT_QUEUE_NAME=orca-agent-pipeline
AGENT_QUEUE_TIMEOUT_SECONDS=300
DAILY_LLM_BUDGET=100
DEBOUNCE_MESSAGE_COUNT=3
DEBOUNCE_SILENCE_SECONDS=8
SUMMARY_MESSAGE_THRESHOLD=15
